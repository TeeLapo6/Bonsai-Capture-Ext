{
    "name": "bonsai-capture",
    "version": "0.1.0",
    "description": "Chrome extension to capture AI chat conversations for Bonsai",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc && node build.js",
        "preview": "vite preview",
        "test": "vitest",
        "test:harness": "node ./node_modules/playwright/cli.js test tests/harness",
        "test:harness:headed": "node ./node_modules/playwright/cli.js test tests/harness --headed",
        "lint": "eslint src --ext ts,tsx"
    },
    "dependencies": {
        "@tiptap/core": "^2.1.0",
        "@tiptap/extension-image": "^2.27.2",
        "@tiptap/extension-link": "^2.27.2",
        "@tiptap/extension-placeholder": "^2.1.0",
        "@tiptap/extension-superscript": "^2.27.2",
        "@tiptap/extension-table": "^2.27.2",
        "@tiptap/extension-table-cell": "^2.27.2",
        "@tiptap/extension-table-header": "^2.27.2",
        "@tiptap/extension-table-row": "^2.27.2",
        "@tiptap/react": "^2.1.0",
        "@tiptap/starter-kit": "^2.1.0",
        "jszip": "^3.10.1",
        "marked": "^17.0.5",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "uuid": "^9.0.0",
        "zustand": "^4.4.0"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/chrome": "^0.0.260",
        "@types/jszip": "^3.4.0",
        "@types/node": "^25.0.3",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/uuid": "^9.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "jsdom": "^28.1.0",
        "typescript": "^5.3.0",
        "vite": "^5.0.0",
        "vite-plugin-static-copy": "^1.0.0",
        "vitest": "^1.0.0"
    }
}
